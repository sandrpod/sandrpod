# SandrPod environment variables
# Copy this file to .env and fill in the values for your environment.
# Never commit a .env file with real credentials.

# ─── API Server ────────────────────────────────────────────────────────────

# Bearer token required for API access (leave empty to disable authentication).
# This single token authenticates as an implicit admin. Poders and agents must
# use an admin token to register.
# SANDRPOD_TOKEN=

# JSON file of named API tokens [{name, token, role}] (role: admin | user),
# additive to SANDRPOD_TOKEN and hot-reloaded on change. See docs/UPGRADING.md.
# SANDRPOD_TOKENS_FILE=/etc/sandrpod/tokens.json

# Public URL of this API server, used when bootstrapping cloud VMs. Must be
# reachable from the VMs. Not required for local/docker providers.
# SANDRPOD_PUBLIC_URL=https://api.example.com

# Built-in TLS (serve HTTPS directly instead of a reverse proxy). Both required.
# SANDRPOD_TLS_CERT=/etc/sandrpod/tls/cert.pem
# SANDRPOD_TLS_KEY=/etc/sandrpod/tls/key.pem

# Per-user-token request rate limit (req/s; 0 = unlimited, admins exempt)
# SANDRPOD_RATE_LIMIT=0

# Max concurrent sandboxes per user token (0 = unlimited, admins exempt)
# SANDRPOD_MAX_SANDBOXES_PER_OWNER=0

# Idle reclamation (cost safety; both OFF/0 by default). Durations like 12h, 30m.
# SANDRPOD_SANDBOX_IDLE_TIMEOUT=12h
# SANDRPOD_PODER_IDLE_TIMEOUT=30m

# Lifecycle webhook sink (fire-and-forget POST on sandbox/poder transitions)
# SANDRPOD_WEBHOOK_URL=https://example.com/hooks/sandrpod

# Persist per-VM SSH keys (DigitalOcean/Hetzner) so a restart doesn't orphan
# existing VMs. Empty = memory-only.
# SANDRPOD_SSH_KEY_DIR=/var/lib/sandrpod/ssh-keys

# Internal URL of THIS instance in a load-balanced multi-instance deployment
# (PostgreSQL-backed); peers forward requests to the node holding a poder's
# tunnel. Empty = single instance.
# SANDRPOD_NODE_URL=http://10.0.1.5:8080

# Poder image started on freshly provisioned cloud VMs. Per-provider override
# via _<PROVIDER> suffix (e.g. SANDRPOD_PODER_IMAGE_ALIYUN for a region-local
# ACR repo).
# SANDRPOD_PODER_IMAGE=ghcr.io/sandrpod/poder:latest

# E2B-compatible gateway: serve the E2B wire protocol on api.<domain> and
# <port>-<sandbox>.<domain> (requires wildcard DNS). Empty = disabled.
# SANDRPOD_E2B_DOMAIN=e2b.example.com
# Placement defaults for E2B create requests that don't specify their own
# SANDRPOD_E2B_PROVIDER=local
# SANDRPOD_E2B_REGION=
# SANDRPOD_E2B_INSTANCE_TYPE=
# Local debugging: serve the E2B gateway in path mode on this port
# (SANDRPOD_E2B_DEBUG_LOG non-empty = verbose request logging)
# SANDRPOD_E2B_DEBUG_PORT=
# SANDRPOD_E2B_DEBUG_LOG=

# ─── Logging & branding (all binaries) ─────────────────────────────────────

# Log level: debug | info | warn | error (default info)
# SANDRPOD_LOG_LEVEL=info

# Log format: text | json (default text)
# SANDRPOD_LOG_FORMAT=text

# Override the product name shown in UI strings and consent dialogs
# SANDRPOD_BRAND=

# ─── Poder (worker node) ───────────────────────────────────────────────────

# URL of the API Server this Poder should register with
API_URL=http://localhost:8080

# Deployment region label (used for scheduling decisions)
REGION=local

# Provider type: local | docker | aws | aliyun | azure | gcp | tencent | digitalocean | hetzner | oracle
PROVIDER_TYPE=local

# Stable Poder identity (auto-generated UUID if not set)
# PODER_ID=

# Directory for the persisted Poder identity (default /var/lib/sandrpod)
# PODER_DATA_DIR=/var/lib/sandrpod

# Cloud VM instance ID this Poder runs on (enables idle VM reclamation)
# VM_INSTANCE_ID=

# Docker network name for sandbox containers (empty = Docker default bridge)
# SANDRPOD_NETWORK=sandrpod

# Docker image used when creating toolbox sandbox containers
SANDRPOD_TOOLBOX_IMAGE=ghcr.io/sandrpod/toolbox:latest

# ─── sandrpod-agent (direct sandbox mode) ──────────────────────────────────

# URL of the API Server to register with
SANDRPOD_API_URL=http://localhost:8080

# Unique sandbox name for this machine (required)
# SANDRPOD_SANDBOX_NAME=my-laptop

# API token to authenticate with the API Server
# SANDRPOD_TOKEN=

# Working directory exposed to code execution (defaults to current dir)
# SANDRPOD_WORK_DIR=/workspace

# Permission gate (employee-PC mode): off | prompt | strict
# SANDRPOD_PERMISSION_MODE=off
# SANDRPOD_PERMISSION_FILE=~/.sandrpod/permissions.json
# Unix socket to the sandrpod-tray consent daemon (prompt mode)
# SANDRPOD_AUTHZ_SOCKET=~/.sandrpod/authz.sock

# Audit pipeline (local NDJSON + optional upload)
# SANDRPOD_AUDIT_DIR=~/.sandrpod/audit
# SANDRPOD_AUDIT_UPLOAD_URL=https://example.com/api/audit/decisions/batch
# SANDRPOD_AUDIT_UPLOAD_TOKEN=

# Optional MCP bridge exposed by the agent (SANDRPOD_MCP_ENABLED /
# _HOT_RELOAD / _GUARD_MANIFEST are honoured by the toolbox too)
# SANDRPOD_MCP_TOKEN=
# SANDRPOD_MCP_LISTEN=
# SANDRPOD_MCP_CONFIG=
# Enable the MCP bridge when mcp.json is present (default true)
# SANDRPOD_MCP_ENABLED=true
# Watch mcp.json and diff-reload on change (default true)
# SANDRPOD_MCP_HOT_RELOAD=true
# Run only the MCP bridge: no tunnel, no toolbox (agent only; default false)
# SANDRPOD_MCP_ONLY=false
# Also require the MCP token on /mcp/manifest (default false: the manifest is
# read-only metadata and stays reachable with platform auth alone)
# SANDRPOD_MCP_GUARD_MANIFEST=false
# Granularity of dialog-issued MCP call grants: server | tool (default server;
# sensitive tools prompt every time in both modes)
# SANDRPOD_MCP_GRANT_SCOPE=server
# Browser OAuth flow for mcp.json entries with auth=oauth (default true)
# SANDRPOD_MCP_OAUTH=true
# Loopback listen address for the OAuth redirect callback
# SANDRPOD_MCP_OAUTH_CALLBACK=127.0.0.1:7099
# Directory for persisted OAuth tokens (default ~/.sandrpod/oauth)
# SANDRPOD_MCP_OAUTH_TOKEN_DIR=
# Extra sensitive-tool keywords, comma-separated; the _OVERRIDE variant
# replaces the built-in list instead of extending it
# SANDRPOD_MCP_SENSITIVE_PATTERNS=
# SANDRPOD_MCP_SENSITIVE_PATTERNS_OVERRIDE=

# ─── Toolbox (in-sandbox code execution service) ───────────────────────────

# Bearer token clients must supply to access the Toolbox HTTP API
# Empty = no authentication (safe when accessed only via yamux tunnel)
# TOOLBOX_TOKEN=

# ─── mcp-gateway (standalone MCP HTTP gateway) ─────────────────────────────

# Bearer token required on gateway endpoints (empty = unauthenticated)
# GATEWAY_ACCESS_TOKEN=

# State directory override
# MCP_GATEWAY_STATE_DIR=

# ─── Cloud provider credentials ────────────────────────────────────────────

# AWS (pkg/provider/aws) — omit to use the default credential chain
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# IAM instance profile attached to provisioned VMs (for SSM run-command)
# AWS_IAM_INSTANCE_PROFILE=

# Alibaba Cloud (pkg/provider/aliyun)
# ALIYUN_ACCESS_KEY=
# ALIYUN_SECRET_KEY=

# Azure (pkg/provider/azure)
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_RESOURCE_GROUP=
# AZURE_SSH_PUBLIC_KEY=

# GCP (pkg/provider/gcp) — SSH-executor backend
# GCP_PROJECT=your-project-id
# GCP_CREDENTIALS_FILE=/path/to/service-account.json

# Tencent Cloud (pkg/provider/tencent)
# TENCENTCLOUD_SECRET_ID=
# TENCENTCLOUD_SECRET_KEY=

# DigitalOcean (pkg/provider/digitalocean) — DO_TOKEN is an accepted alias
# DIGITALOCEAN_TOKEN=

# Hetzner Cloud (pkg/provider/hetzner)
# HCLOUD_TOKEN=

# Oracle Cloud (pkg/provider/oracle)
# OCI_CONFIG_FILE=~/.oci/config
# OCI_COMPARTMENT_OCID=
# OCI_AVAILABILITY_DOMAIN=

# ─── Cloud VM network overrides (optional; per-provider _<PROVIDER> suffix) ───
# SANDRPOD_VM_SUBNET_ID / _AWS / _ALIYUN — subnet (or VPC UUID for DigitalOcean)
# SANDRPOD_VM_SECURITY_GROUP_ALIYUN
# SANDRPOD_VM_PUBLIC_IP / _AWS — force-assign a public IP (true/false)
